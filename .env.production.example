APP_NAME="Cimuning Digital Hub"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.com
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

FORCE_HTTPS=true
TRUSTED_HOSTS=example.com,www.example.com
# Kosongkan untuk cPanel langsung. Gunakan * hanya saat seluruh traffic melewati reverse proxy tepercaya.
TRUSTED_PROXIES=
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000

BCRYPT_ROUNDS=12
AUTH_PASSWORD_RESET_ENABLED=false
RUN_DATABASE_SEEDERS=false
SCHEDULER_MAX_AGE_MINUTES=5

SUPPORT_EMAIL=cimuningppk@gmail.com
SUPPORT_WHATSAPP=6287804054071
SUPPORT_WHATSAPP_DISPLAY=0878-0405-4071
SUPPORT_WHATSAPP_MESSAGE="Halo Admin Cimuning Digital Hub, saya membutuhkan bantuan."

# cPanel: LOG_STACK=daily. Docker/VPS: LOG_STACK=stderr.
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning
LOG_DAILY_DAYS=14

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CACHE_STORE=database
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=log

BACKUP_ENABLED=true
BACKUP_MYSQLDUMP_PATH=
BACKUP_TIMEOUT_SECONDS=120
BACKUP_MAX_ARCHIVE_BYTES=262144000
BACKUP_MAX_UNCOMPRESSED_BYTES=1073741824
BACKUP_ARCHIVE_TTL_MINUTES=60
BACKUP_COOLDOWN_MINUTES=15

FILESYSTEM_DISK=cloudinary
LIVEWIRE_TEMPORARY_FILE_UPLOAD_DISK=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=cimuning
CLOUDINARY_SIGNED_URLS=true

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
