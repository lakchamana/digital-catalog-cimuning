APP_NAME="Cimuning Digital Hub"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.railway.app

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Jakarta

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12
AUTH_PASSWORD_RESET_ENABLED=false
FORCE_HTTPS=true
TRUSTED_HOSTS=your-app.railway.app
TRUSTED_PROXIES=*
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000
RUN_DATABASE_SEEDERS=false
SCHEDULER_MAX_AGE_MINUTES=5

SUPPORT_EMAIL=cimuningppk@gmail.com
SUPPORT_WHATSAPP=6287804054071
SUPPORT_WHATSAPP_DISPLAY=0878-0405-4071
SUPPORT_WHATSAPP_MESSAGE="Halo Admin Cimuning Digital Hub, saya membutuhkan bantuan."

LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── DATABASE (Railway MySQL Plugin) ──────────────────────────────────────────
# Isi dari tab "Variables" Railway setelah MySQL plugin ditambahkan.
# Railway otomatis menyediakan MYSQL_URL, tapi lebih aman pakai per-variable.
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# ─── SESSION & CACHE ───────────────────────────────────────────────────────────
# Ganti ke database agar tidak bergantung pada filesystem Railway yang ephemeral
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CACHE_STORE=database
QUEUE_CONNECTION=sync

# Backup database terenkripsi (admin-only). Kosongkan path di Railway/Docker.
# Lokal Windows otomatis memakai C:\xampp\mysql\bin\mysqldump.exe bila tersedia.
BACKUP_ENABLED=true
BACKUP_MYSQLDUMP_PATH=
BACKUP_TIMEOUT_SECONDS=120
BACKUP_MAX_ARCHIVE_BYTES=262144000
BACKUP_MAX_UNCOMPRESSED_BYTES=1073741824
BACKUP_ARCHIVE_TTL_MINUTES=60
BACKUP_COOLDOWN_MINUTES=15

BROADCAST_CONNECTION=log

# ─── FILESYSTEM (Cloudinary) ───────────────────────────────────────────────────
# Set ke "cloudinary" di production agar file upload disimpan ke Cloudinary.
FILESYSTEM_DISK=cloudinary
LIVEWIRE_TEMPORARY_FILE_UPLOAD_DISK=local

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=cimuning
CLOUDINARY_SIGNED_URLS=true

# ─── MAIL ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@cimuning.id"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
