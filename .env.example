APP_NAME="Cimuning Digital Hub"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.railway.app

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── DATABASE (Railway MySQL Plugin) ──────────────────────────────────────────
# Isi dari tab "Variables" Railway setelah MySQL plugin ditambahkan.
# Railway otomatis menyediakan MYSQL_URL, tapi lebih aman pakai per-variable.
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# ─── SESSION & CACHE ───────────────────────────────────────────────────────────
# Ganti ke database agar tidak bergantung pada filesystem Railway yang ephemeral
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=sync

BROADCAST_CONNECTION=log

# ─── FILESYSTEM (Cloudinary) ───────────────────────────────────────────────────
# Set ke "cloudinary" di production agar file upload disimpan ke Cloudinary.
FILESYSTEM_DISK=cloudinary
LIVEWIRE_TEMPORARY_FILE_UPLOAD_DISK=local

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=cimuning

# ─── MAIL ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@cimuning.id"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
